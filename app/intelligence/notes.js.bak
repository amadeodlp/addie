/**
 * notes.js — Project knowledge extraction from conversations.
 *
 * At the end of each conversation, reads the full chat log and the current
 * addie-notes.md, then asks the LLM to produce a consolidated, up-to-date
 * version — integrating new knowledge and resolving contradictions in favor
 * of the most recent conversation.
 *
 * The output REPLACES addie-notes.md entirely. No append, no accumulation
 * of contradictions. The file always reflects current project knowledge.
 */

'use strict';

const context = require('../state/context');
const llm     = require('../services/llm');

const NOTES_FILENAME = 'addie-notes.md';
const MIN_WORDS      = 80;

const SYSTEM_PROMPT = `You are maintaining a project knowledge file for a music producer working in Ableton Live.

You will receive:
1. A conversation log between the producer and Addie (an AI assistant)
2. The current project notes (may be empty or a placeholder)

Your job: produce an updated version of the project notes capturing durable knowledge from this conversation.

WHAT TO CAPTURE:
- Musical direction and creative intent ("este track es techno industrial, sin melodias suaves")
- Confirmed decisions about the project ("decidimos no usar reverb en el kick, todo seco")
- Constraints the producer stated explicitly ("el vocal no puede superar -6 dB de compresion")
- Workflow context specific to this project ("hay un bus paralelo de bateria, no agregar compresion directa al kick")
- Corrections the producer made to Addie suggestions ("pidio EQ nativo en lugar de Pro-Q 3")
- Plugin or sound choices confirmed for specific tracks in this project

WHAT NOT TO CAPTURE:
- Specific parameter values (they change constantly)
- Mixer levels, volumes, pan positions
- Anything prefixed with "for now" or clearly temporary
- Session structure details — stale immediately

CONSOLIDATION RULES:
- If current notes contradict something from this conversation, the conversation wins
- Remove outdated info, do not just append to it
- Keep notes concise — bullet points, no long paragraphs
- If nothing meaningful to capture, return the placeholder text unchanged
- Write in the same language the producer used

OUTPUT FORMAT: return ONLY the markdown content, starting directly with the notes.
No preamble, no explanation, no markdown code fences.
First line must be: ## Notas del proyecto  (or ## Project notes if conversation is in English)
Keep it under 400 words.`;

